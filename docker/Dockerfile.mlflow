# Custom MLflow image with postgres driver baked in.
# Vendor image (ghcr.io/mlflow/mlflow:v2.11.1) ships without psycopg2,
# but we use postgres as the backend store. Adding psycopg2-binary here
# avoids runtime pip-install hacks and keeps the image immutable.
FROM ghcr.io/mlflow/mlflow:v2.11.1

RUN pip install --no-cache-dir psycopg2-binary==2.9.10
