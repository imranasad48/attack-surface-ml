# Template for the .env file used by docker-compose.prod.yml on the EC2 host.
# Copy to .env on the EC2 box and fill in. .env is gitignored.
#
# IMPORTANT: DATABASE_URL and MLFLOW_TRACKING_URI are overridden in
# docker-compose.prod.yml's environment: block to point at the in-compose
# service names (postgres, mlflow). Values here are documentation only;
# the override wins.

# Application
APP_ENV=production
LOG_LEVEL=INFO

# API auth — REGENERATE this for production. Generate a strong key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Save the generated value in BOTH this .env file AND a secure note for the
# viva demo (faculty examiners hit /predict with this key in the X-API-Key header).
API_KEY=REPLACE-WITH-GENERATED-SECRET

# Database — overridden by compose to postgresql://asm:asm@postgres:5432/asm
DATABASE_URL=postgresql://asm:asm@postgres:5432/asm

# MLflow — overridden by compose to http://mlflow:5000
MLFLOW_TRACKING_URI=http://mlflow:5000

# Optional — leave blank if not using NVD's authenticated API
# (rate limit drops from 50 req / 30s to 5 req / 30s without a key)
NVD_API_KEY=

# Phase 2 — cosign artifact signing (not used in v1 deployment)
COSIGN_PASSWORD=
