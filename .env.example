# Copy to .env and fill in. .env is gitignored.

# Application
APP_ENV=development
LOG_LEVEL=INFO
API_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://asm:asm@localhost:5432/asm

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# External feeds (optional; NVD/EPSS/KEV are public)
NVD_API_KEY=

# Cosign (for artifact signing in CI)
# Generated by: cosign generate-key-pair
COSIGN_PASSWORD=
